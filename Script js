document.addEventListener("DOMContentLoaded", function() {
    const button = document.querySelector(".calculate-btn");
    const summarySection = document.getElementById("summarySection");
    const resultSection = document.getElementById("resultSection");
    const summaryText = document.getElementById("summaryText");
    const yearlyTable = document.getElementById("yearlyTable");
    const chartCanvas = document.getElementById("assetChart");
    let chart;

    // 천 단위 콤마 포맷 함수
    function formatNum(num) {
        return Math.round(num).toLocaleString();
    }

    // Y축 억 단위 표시용 함수
    function formatEok(value) {
        if (value === 0) return '0';
        return (value / 10000).toFixed(1) + '억';
    }

    button.addEventListener("click", function() {
        // 1. 입력값 가져오기
        const ageSelf = parseInt(document.getElementById("ageSelf").value) || 0;
        const agePartner = parseInt(document.getElementById("agePartner").value) || 0;
        let currentAsset = parseFloat(document.getElementById("assetTotal").value) || 0;
        const incomeSelf = parseFloat(document.getElementById("incomeSelf").value) || 0;
        const incomePartner = parseFloat(document.getElementById("incomePartner").value) || 0;
        const incomeGrowth = (parseFloat(document.getElementById("incomeGrowth").value) || 0) / 100;
        const expenseTotal = parseFloat(document.getElementById("expenseTotal").value) || 0;
        const interestRate = (parseFloat(document.getElementById("interestRate").value) || 0) / 100;
        const expenseInflation = (parseFloat(document.getElementById("expenseInflation").value) || 0) / 100;
        const retireSelf = parseInt(document.getElementById("retireSelf").value) || 0;
        const retirePartner = parseInt(document.getElementById("retirePartner").value) || 0;
        
        const childCount = parseInt(document.getElementById("childCount").value) || 0;
        const childYearsRemaining = parseInt(document.getElementById("childYearsRemaining").value) || 0;
        const childAnnualExpense = parseFloat(document.getElementById("childAnnualExpense").value) || 0;

        const maxAge = 100;
        const years = maxAge - ageSelf;

        let labels = [];
        let assetData = [];
        let incomeData = [];
        let expenseData = [];
        let childExpenseData = [];

        yearlyTable.innerHTML = "";
        let bankruptAge = null;
        let fireAge = null;

        // 2. 연도별 계산
        for (let i = 0; i <= years; i++) {
            let curAgeS = ageSelf + i;
            let curAgeP = agePartner + i;

            let curIncS = curAgeS < retireSelf ? incomeSelf * Math.pow(1 + incomeGrowth, i) : 0;
            let curIncP = curAgeP < retirePartner ? incomePartner * Math.pow(1 + incomeGrowth, i) : 0;
            let annualIncome = curIncS + curIncP;

            let adjExpense = expenseTotal * Math.pow(1 + expenseInflation, i);
            let childExp = (childCount > 0 && i < childYearsRemaining) ? 
                           (childCount * childAnnualExpense * Math.pow(1 + expenseInflation, i)) : 0;
            let totalExp = adjExpense + childExp;

            let passiveIncome = currentAsset > 0 ? currentAsset * interestRate : 0;
            if (fireAge === null && passiveIncome >= totalExp && currentAsset > 0) fireAge = curAgeS;

            currentAsset = currentAsset * (1 + interestRate) + annualIncome - totalExp;
            if (currentAsset < 0 && bankruptAge === null) bankruptAge = curAgeS;

            // 테이블 채우기
            let tr = document.createElement("tr");
            tr.innerHTML = `<td>${curAgeS}(${curAgeP})</td><td>${formatNum(currentAsset)}</td><td>${formatNum(annualIncome)}</td><td>${formatNum(adjExpense)}</td><td>${formatNum(childExp)}</td>`;
            yearlyTable.appendChild(tr);

            // 그래프 데이터 (X축에 본인/배우자 나이 병기)
            labels.push(`${curAgeS}(${curAgeP})`);
            assetData.push(currentAsset);
            incomeData.push(annualIncome);
            expenseData.push(totalExp);
            childExpenseData.push(childExp);
        }

        // 3. 요약 텍스트
        summarySection.style.display = "block";
        resultSection.style.display = "block";
        
        let resultMsg = bankruptAge ? 
            `이대로면 <span class="highlight-red">${bankruptAge}세에 파산</span>합니다.` : 
            (fireAge ? `<span class="highlight-blue">${fireAge}세에 경제적 자유</span> 달성!` : "안정적인 자산 흐름입니다.");
        
        summaryText.innerHTML = `<h3>${resultMsg}</h3><p>단위: 만원 / 수익률: ${(interestRate*100).toFixed(1)}% / 인플레: ${(expenseInflation*100).toFixed(1)}%</p>`;

        // 4. 그래프 생성 (단일 축, 억 단위, 선 두껍게)
        if (chart) chart.destroy();
        chart = new Chart(chartCanvas, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { label: '누적 순자산', data: assetData, borderColor: '#3182f6', borderWidth: 4, fill: false, tension: 0.1 },
                    { label: '총 수입', data: incomeData, borderColor: '#20c997', borderWidth: 3, borderDash: [5, 5], fill: false },
                    { label: '총 지출', data: expenseData, borderColor: '#f04452', borderWidth: 3, fill: false },
                    { label: '자녀 지출', data: childExpenseData, borderColor: '#ff9800', borderWidth: 3, fill: false }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        position: 'left',
                        ticks: {
                            callback: function(value) { return formatEok(value); },
                            stepSize: 50000 // 5억 단위 그리드 권장
                        },
                        title: { display: true, text: '금액 (억 단위)' }
                    },
                    x: {
                        title: { display: true, text: '본인나이(배우자나이)' },
                        ticks: { maxRotation: 45, minRotation: 45 }
                    }
                },
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + formatNum(context.raw) + ' 만원';
                            }
                        }
                    }
                }
            }
        });
        
        // 버튼 클릭 후 그래프로 스크롤 이동
        resultSection.scrollIntoView({ behavior: 'smooth' });
    });
});
